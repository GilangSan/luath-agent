# Groq AI (Preferred)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx
# RECOMMENDED: Use llama-3.3-70b-versatile. It is more stable and has better rate limits than the 8B models.
GROQ_MODEL=llama-3.3-70b-versatile

# Exa AI Search
EXA_API_KEY=exa-xxxxxxxxxxxxxxxxxxxx

# OpenRouter AI (Fallback)
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# RapidAPI (optional)
RAPIDAPI_KEY=xxxxxxxxxxxxxxxxxxxx

# OpenWeatherMap API
OPENWEATHER_API_KEY=xxxxxxxxxxxxxxxxxxxx

# Bot Config
BOT_NAME=Luath
OWNER_NAME=Lang
OWNER_NUMBER=628xxxxxxxxx
BOT_NUMBER=628xxxxxxxxx
BOT_PREFIX=/
MAX_HISTORY=10
